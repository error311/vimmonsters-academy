NODE_ENV=production
HOST=0.0.0.0
PORT=8002

# Use a long random secret in production.
COMPETITIVE_SECRET=replace-this-with-a-long-random-secret

# Store these outside the repo when hosting publicly.
LEADERBOARD_PATH=./data/leaderboard.json
COMPETITION_STATE_PATH=./data/competition-state.json

# Optional competition guardrails.
MIN_RUN_MS=60000
MAX_RUN_MS=10800000
MAX_SCORE=7000
MAX_SCORE_PER_SECOND=35

# Optional API hardening.
MAX_BODY_BYTES=8192
RATE_LIMIT_WINDOW_MS=60000
START_LIMIT=30
SUBMIT_LIMIT=20
RENAME_LIMIT=20
RUN_SUBMIT_DRIFT_MS=30000
